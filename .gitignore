# This is the plugin SOURCE repo. The eval harness (harness/, scenarios/, tests/) is
# tracked here so the skills' expected behavior travels with the code; it is excluded
# from the DISTRIBUTED plugin via .claudeignore, not from git. Only runtime artifacts
# and customer data are git-ignored.

# --- Eval run output — contains real Modjo deal data, NEVER commit (the harness itself IS tracked) ---
eval/results/

# --- Customer data / runtime artifacts — NEVER commit (contain real Modjo deal data) ---
outputs/

# --- Private project memory & dev process artifacts ---
memory/
docs/

# --- Local Claude Code settings ---
.claude/

# --- Python ---
__pycache__/
*.pyc
.pytest_cache/

# --- OS ---
.DS_Store
